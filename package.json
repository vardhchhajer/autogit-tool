{
  "name": "autogit-cli",
  "version": "1.0.0",
  "description": "Automate project documentation, GitHub publishing, and social media content generation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "autogit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "git",
    "github",
    "documentation",
    "readme",
    "automation",
    "publishing",
    "linkedin",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "diff": "^5.2.0",
    "globby": "^14.0.2",
    "inquirer": "^9.3.7",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "octokit": "^4.0.2",
    "cli-table3": "^0.6.5",
    "marked": "^14.1.0",
    "marked-terminal": "^7.1.0",
    "dotenv": "^16.4.5",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.2",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
